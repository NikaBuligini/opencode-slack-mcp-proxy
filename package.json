{
  "name": "opencode-slack-mcp-proxy",
  "version": "1.0.0",
  "description": "Local OAuth proxy that makes Slack MCP work with opencode by adapting Slack's Claude Code-oriented OAuth flow.",
  "keywords": [
    "mcp",
    "oauth",
    "opencode",
    "proxy",
    "slack"
  ],
  "license": "MIT",
  "author": "Nikoloz Buligini <nbuligini11@gmail.com>",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "lint": "pnpm exec oxlint .",
    "prestart": "pnpm run build",
    "start": "node build/index.js",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:all": "pnpm run check && pnpm run test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "oxc-parser": "^0.121.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.17.1"
}
